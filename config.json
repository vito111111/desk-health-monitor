{
  "_comment": "桌前健康关怀助手配置。阈值因人/摄像头/光线而异，可在看板观察实时值后微调。",

  "camera_index": 0,
  "frame_width": 640,
  "frame_height": 480,
  "target_fps": 15,
  "pose_interval": 0.33,
  "sample_interval": 30,

  "away_seconds": 5,
  "distracted_yaw_deg": 25,
  "distracted_pitch_deg": 22,
  "distracted_grace_seconds": 2.5,

  "ear_closed_threshold": 0.19,
  "drowsy_closed_seconds": 1.5,
  "perclos_window_seconds": 60,
  "perclos_drowsy_ratio": 0.4,
  "mar_yawn_threshold": 0.6,
  "yawn_min_seconds": 1.2,
  "blink_min_seconds": 0.08,

  "comfort_distance_cm": 60,
  "min_distance_cm": 45,
  "eye_break_minutes": 20,
  "dry_eye_blink_rate": 8,
  "dry_eye_seconds": 30,

  "slouch_drop_ratio": 0.18,
  "sedentary_minutes": 45,

  "posture": {
    "calib_frames": 25,
    "smooth_alpha": 0.35,
    "min_visibility": 0.6,
    "enter_hold_sec": 2.5,
    "exit_hold_sec": 2.0,
    "neck_drop_enter": 0.15,
    "neck_drop_exit": 0.09,
    "fwd_rise_enter": 0.15,
    "fwd_rise_exit": 0.09,
    "shoulder_tilt_deg": 8.5,
    "shoulder_tilt_exit_deg": 4.5,
    "head_tilt_deg": 9.0,
    "body_lean_ratio": 0.16
  },

  "rppg_buffer": 300,
  "rppg_min_samples": 150,
  "rppg_calc_interval": 2.0,
  "rppg_quality_min": 0.06,
  "high_stress_threshold": 60,

  "affect": {
    "smooth_alpha": 0.08
  },
  "env": {
    "dark_lum": 55,
    "bright_lum": 230,
    "smooth_alpha": 0.05,
    "hold_sec": 12
  },
  "rhythm": {
    "talk_mar": 0.42,
    "talk_min_openings": 5,
    "talk_window_sec": 12,
    "talk_release_sec": 6,
    "defer_types": ["need_move", "need_eye_break"],
    "max_defer_sec": 150,
    "quiet_hours": [],
    "dnd": false
  },

  "_intervention_comment": "主动健康干预: 读累积统计->本地规则识别风险->claude CLI 生成行动建议, 落盘+归档 Obsidian, alert 级风险主动推送桌宠。非医疗诊断。",
  "intervention": {
    "enabled": true,
    "interval_sec": 14400,
    "use_llm": true,
    "sleep_debt_min": 360,
    "sleep_debt_days": 3,
    "resting_hr_warn": 75,
    "resting_hr_rise": 6,
    "low_steps": 3000,
    "low_steps_days": 3,
    "stress_warn": 60,
    "stress_days": 3,
    "slouch_ratio_warn": 30,
    "slouch_days": 3,
    "low_score": 55,
    "low_score_days": 3
  },

  "daily_report": true,
  "report_interval": 600,
  "score_streak_threshold": 70,
  "obsidian_health_dir": "G:\\ClaudeCode应用\\70-健康日志",

  "auto_lock": false,
  "auto_lock_seconds": 30,

  "pet_integration": true,

  "_sound_comment": "健康提醒改由桌宠右侧疲劳条以颜色+闪烁安静提示，故关闭蜂鸣；弹窗也已由疲劳条取代。",
  "sound_alert": false,
  "reminder_default_cooldown": 120,
  "reminder_cooldowns": {
    "drowsy": 90,
    "slouch": 90,
    "high_shoulder": 180,
    "need_move": 300,
    "need_eye_break": 300,
    "dry_eye": 180,
    "too_close": 90,
    "high_stress": 300,
    "dark_env": 600
  },
  "_sustain_comment": "问题须连续存在 N 秒才提醒，过滤瞬时/轻微波动；疲劳关乎安全故即时提醒。",
  "reminder_default_sustain": 5,
  "reminder_sustain_seconds": {
    "drowsy": 0,
    "slouch": 25,
    "high_shoulder": 45,
    "need_move": 0,
    "need_eye_break": 0,
    "dry_eye": 10,
    "too_close": 12,
    "high_stress": 10,
    "dark_env": 20
  },

  "privacy_no_video_save": true,
  "dashboard_host": "127.0.0.1",
  "dashboard_port": 5005,
  "db_path": "monitor.db"
}
